/*
(1) Creates two new users: [your-UOW-email]_1 and [your-UOW-email]_2. The passwords are up to you.

For example, if your UOW email account is abc001@uow.edu.au, then the first user is abc001_1, and the second user is abc001_2.
*/


CREATE USER 'ntt607_1'@'localhost' IDENTIFIED BY 'password123'
