/*
Display the property number, city, street and price for the properties that are preferred.
*/

SELECT DISTINCT PR.PNumber, PR.city, PR.street, PR.price
FROM PROPERTY PR JOIN PREFERENCE P 
  ON PR.city = P.PCity 
 AND PR.street = P.PStreet
WHERE PR.price >= IFNULL(P.minPrice, 0)
  AND PR.price <= IFNULL(P.maxPrice, 9999999.99)
