/*
(4)	Implement the questions below by using the advanced DML and query statements.

Increase the price by 1% for the properties which are preferred.
If a property is in the same city and street as preferred by any buyers, and the price is in the range of the preferred minimum and maximum prices.

Note that the minimum price is 0 if it is NULL, and the maximum price is the maximum value (9999999.99) if it is NULL.
*/

UPDATE PROPERTY
SET price = price * 1.01
WHERE PNumber IN (
    SELECT temp.PNumber FROM (
        SELECT DISTINCT PR.PNumber
        FROM PROPERTY PR JOIN PREFERENCE P 
          ON PR.city = P.PCity 
         AND PR.street = P.PStreet
        WHERE PR.price >= IFNULL(P.minPrice, 0)
          AND PR.price <= IFNULL(P.maxPrice, 9999999.99)
    ) AS temp
)
--------------

Query OK, 3 rows affected (0.01 sec)
Rows matched: 3  Changed: 3  Warnings: 0

