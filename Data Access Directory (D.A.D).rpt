/* 
Your implementation must directly follow a comment with the specifications of a subtask.
*/

/*
(1) Implement SELECT statements in a WITH clause for the query below.

    Find the buyer’s phone numbers and names of all buyers who have properties in Wollongong that satisfy their preferences.
	A buyer prefers a property if the property is located in the same city and street as preferred by the buyer, and the price is in the range of the preferred minimum and maximum prices.
    Note that the minimum price is 0 if it is NULL, and the maximum price is the maximum value (9999999.99) if it is NULL.

    You must implement at least 2 subqueries in the WITH clause for this question.
*/


WITH WOLLONGONG_PROP AS (
    SELECT PNumber, city, street, price
    FROM PROPERTY
    WHERE city = 'Wollongong'
),
MATCHED_PREF AS (
    SELECT DISTINCT P.BPhoneNumber
    FROM PREFERENCE P JOIN WOLLONGONG_PROP WP 
      ON WP.city = P.PCity 
     AND WP.street = P.PStreet
    WHERE WP.price >= IFNULL(P.minPrice, 0)
      AND WP.price <= IFNULL(P.maxPrice, 9999999.99)
)
SELECT B.BPhoneNumber, B.name
FROM BUYER B JOIN MATCHED_PREF MP 
  ON B.BPhoneNumber = MP.BPhoneNumber
--------------

