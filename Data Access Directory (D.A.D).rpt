/*
(5) Implement the questions below by using the advanced DML statements.

Remove the owners from the database who haven’t owned any properties.
*/


DELETE FROM OWNER
WHERE OPhoneNumber NOT IN (
    SELECT DISTINCT OPhoneNumber 
    FROM PROPERTY
)
