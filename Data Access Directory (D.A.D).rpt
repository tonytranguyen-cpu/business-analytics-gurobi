/* 
(2)	Use relational views to implement the questions below. 

    Find the owner’s phone numbers and names of all owners who have properties in Wollongong that are preferred.
	A buyer prefers a property if the property is located in the same city and street as preferred by the buyer, and the price is in the range of the preferred minimum and maximum prices.
    Note that the minimum price is 0 if it is NULL, and the maximum price is the maximum value (9999999.99) if it is NULL.

    You must create at least 2 views to implement the query above.
*/

CREATE VIEW VIEW_PREFERRED_PROP AS
SELECT DISTINCT PR.PNumber, PR.OPhoneNumber, PR.city
FROM PROPERTY PR JOIN PREFERENCE P 
  ON PR.city = P.PCity 
 AND PR.street = P.PStreet
WHERE PR.price >= IFNULL(P.minPrice, 0)
  AND PR.price <= IFNULL(P.maxPrice, 9999999.99)
--------------

Query OK, 0 rows affected (0.01 sec)

--------------
CREATE VIEW VIEW_WOLLONGONG_OWNERS AS
SELECT DISTINCT O.OPhoneNumber, O.OName
FROM OWNER O JOIN VIEW_PREFERRED_PROP VPP 
  ON O.OPhoneNumber = VPP.OPhoneNumber
WHERE VPP.city = 'Wollongong'
