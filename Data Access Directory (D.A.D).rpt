/*
(3) Implement the questions below by using the advanced DDL and other required statements.

Create a relational table named OwnerProperties and insert information for each owner, including their phone number, name, the total number and total price of properties owned by each owner, including owners who have no properties.

Note that you must create the relational table OwnerProperties and insert information into the table by using one advanced DDL statement.
*/


CREATE TABLE OwnerProperties AS
SELECT O.OPhoneNumber, O.OName, 
       COUNT(P.PNumber) AS TotalProperties, 
       IFNULL(SUM(P.price), 0) AS TotalPrice
FROM OWNER O LEFT JOIN PROPERTY P 
  ON O.OPhoneNumber = P.OPhoneNumber
GROUP BY O.OPhoneNumber, O.OName
--------------

